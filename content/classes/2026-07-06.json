  "grammar": [
    {
      "id": "2026-07-06:grammar:tachi-plural",
      "type": "grammar",
      "pattern": "〜たち",
      "es": "El sufijo 〜たち forma el plural de personas y pronombres.",
      "examples": [
        {
          "kanji": "私たち",
          "kana": "わたしたち",
          "romaji": "watashitachi",
          "es": "nosotros"
        },
        {
          "kanji": "あなたたち",
          "kana": "あなたたち",
          "romaji": "anatatachi",
          "es": "vosotros / ustedes"
        }
      ],
      "tags": [
        "2026-07-06",
        "gramática"
      ]
    },
    {
      "id": "2026-07-06:grammar:numeros",
      "type": "grammar",
      "pattern": "Números 0–99",
      "es": "Base 1–10: いち(1), に(2), さん(3), よん(4), ご(5), ろく(6), なな(7), はち(8), きゅう(9), じゅう(10); 0 = れい / ゼロ. Las decenas se forman con じゅう: 11 = じゅういち, 20 = にじゅう, 99 = きゅうじゅうきゅう.",
      "examples": [
        {
          "kanji": "十",
          "kana": "じゅう",
          "romaji": "juu",
          "es": "diez (10)"
        },
        {
          "kanji": "九十九",
          "kana": "きゅうじゅうきゅう",
          "romaji": "kyuujuukyuu",
          "es": "noventa y nueve (99)"
        }
      ],
      "tags": [
        "2026-07-06",
        "gramática",
        "números"
      ]
    },
    {
      "id": "2026-07-06:grammar:sai-edad",
      "type": "grammar",
      "pattern": "número + さい",
      "es": "El contador 〜歳（さい）indica la edad; se coloca tras el número.",
      "examples": [
        {
          "kanji": "十二歳",
          "kana": "じゅうにさい",
          "romaji": "juuni sai",
          "es": "doce años"
        }
      ],
      "tags": [
        "2026-07-06",
        "gramática",
        "números"
      ]
    }
  ],
