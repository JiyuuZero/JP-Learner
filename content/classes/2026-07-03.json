  "grammar": [
    {
      "id": "2026-07-03:grammar:desu",
      "type": "grammar",
      "pattern": "〜です",
      "es": "Cópula cortés «ser/estar». Se añade al final de la frase para afirmar que algo es X.",
      "examples": [
        {
          "kanji": "水です。",
          "kana": "みずです。",
          "romaji": "Mizu desu.",
          "es": "Es agua."
        },
        {
          "kanji": "これはコートです。",
          "kana": "これはコートです。",
          "romaji": "Kore wa kooto desu.",
          "es": "Esto es un abrigo."
        }
      ],
      "tags": [
        "2026-07-03",
        "gramática",
        "partícula"
      ]
    },
    {
      "id": "2026-07-03:grammar:no-posesivo",
      "type": "grammar",
      "pattern": "AのB",
      "es": "La partícula の une dos nombres e indica posesión o pertenencia: «AのB» = «el B de A».",
      "examples": [
        {
          "kanji": "私のコート",
          "kana": "わたしのコート",
          "romaji": "watashi no kooto",
          "es": "mi abrigo"
        },
        {
          "kanji": "私のコートは赤いです。",
          "kana": "わたしのコートはあかいです。",
          "romaji": "Watashi no kooto wa akai desu.",
          "es": "Mi abrigo es rojo."
        }
      ],
      "tags": [
        "2026-07-03",
        "gramática",
        "partícula"
      ]
    },
    {
      "id": "2026-07-03:grammar:wa-tema",
      "type": "grammar",
      "pattern": "〜は〜です",
      "es": "La partícula は (se pronuncia «wa») marca el tema de la frase: «en cuanto a ~».",
      "examples": [
        {
          "kanji": "田中さんはかっこいいです。",
          "kana": "たなかさんはかっこいいです。",
          "romaji": "Tanaka-san wa kakkoii desu.",
          "es": "El señor Tanaka es guay."
        },
        {
          "kanji": "かばんはここです。",
          "kana": "かばんはここです。",
          "romaji": "Kaban wa koko desu.",
          "es": "El bolso está aquí."
        }
      ],
      "tags": [
        "2026-07-03",
        "gramática",
        "partícula"
      ]
    },
    {
      "id": "2026-07-03:grammar:ka-interrogativa",
      "type": "grammar",
      "pattern": "〜ですか",
      "es": "La partícula か al final de la frase la convierte en pregunta.",
      "examples": [
        {
          "kanji": "白い手袋はどこですか。",
          "kana": "しろいてぶくろはどこですか。",
          "romaji": "Shiroi tebukuro wa doko desu ka.",
          "es": "¿Dónde está el guante blanco?"
        }
      ],
      "tags": [
        "2026-07-03",
        "gramática",
        "partícula"
      ]
    }
  ],
  "kanji": [],
  "notes": [
    {
      "id": "2026-07-03:note:1",
      "type": "note",
      "es": "コート (abrigo) se escribe en katakana por ser un préstamo del inglés «coat».",
      "tags": [
        "2026-07-03"
      ]
    },
    {
      "id": "2026-07-03:note:2",
      "type": "note",
      "es": "La partícula de tema は se escribe con la sílaba «ha» pero se pronuncia «wa».",
      "tags": [
        "2026-07-03"
      ]
    }
  ]
