  "grammar": [
    {
      "id": "2026-07-10:grammar:kono-sono-ano",
      "type": "grammar",
      "pattern": "この・その・あの + sustantivo",
      "es": "«este/ese/aquel + sustantivo». これ・それ・あれ van solos y llevan は directamente (これは…); この・その・あの SIEMPRE necesitan un sustantivo detrás. Ej.: これ → このほん (este libro), そのくるま (ese coche), あのひと (aquella persona).",
      "examples": [
        {
          "kanji": "このほんはわたしのです。",
          "kana": "このほんはわたしのです。",
          "romaji": "kono hon wa watashi no desu.",
          "es": "Este libro es mío."
        },
        {
          "kanji": "あのひとはだれですか。",
          "kana": "あのひとはだれですか。",
          "romaji": "ano hito wa dare desu ka.",
          "es": "¿Quién es aquella persona?"
        }
      ],
      "tags": [
        "2026-07-10",
        "gramática",
        "demostrativos"
      ]
    },
    {
      "id": "2026-07-10:grammar:koko-soko-asoko",
      "type": "grammar",
      "pattern": "ここ・そこ・あそこ",
      "es": "Demostrativos de LUGAR: ここ = aquí (donde estoy), そこ = ahí (cerca de ti), あそこ = allí (lejos de los dos). Para preguntar «¿dónde?» se usa どこ.",
      "examples": [
        {
          "kanji": "トイレはあそこです。",
          "kana": "トイレはあそこです。",
          "romaji": "toire wa asoko desu.",
          "es": "El baño está allí."
        },
        {
          "kanji": "おてあらいはどこですか。",
          "kana": "おてあらいはどこですか。",
          "romaji": "otearai wa doko desu ka.",
          "es": "¿Dónde está el baño?"
        }
      ],
      "tags": [
        "2026-07-10",
        "gramática",
        "demostrativos",
        "lugares"
      ]
    },
    {
      "id": "2026-07-10:grammar:nanno-desuka",
      "type": "grammar",
      "pattern": "… は なんの … ですか",
      "es": "Para preguntar «¿de qué es X?» (de qué trata) se usa なんの + sustantivo + ですか. Se responde con «A の B». Ej.: なんのほんですか → にほんごのほんです («¿de qué es el libro?» → «es un libro de japonés»).",
      "examples": [
        {
          "kanji": "これはなんのほんですか。",
          "kana": "これはなんのほんですか。",
          "romaji": "kore wa nan no hon desu ka.",
          "es": "¿De qué es este libro? (¿de qué trata?)"
        },
        {
          "kanji": "にほんごのほんです。",
          "kana": "にほんごのほんです。",
          "romaji": "nihongo no hon desu.",
          "es": "Es un libro de japonés."
        }
      ],
      "tags": [
        "2026-07-10",
        "gramática",
        "preguntas"
      ]
    },
    {
      "id": "2026-07-10:grammar:dareno-desuka",
      "type": "grammar",
      "pattern": "… は だれの … ですか",
      "es": "Para preguntar «¿de quién es X?» se usa だれの + sustantivo + ですか. Se responde con «(persona) の です». Ej.: だれのほんですか → わたしのです («¿de quién es el libro?» → «es mío»).",
      "examples": [
        {
          "kanji": "これはだれのほんですか。",
          "kana": "これはだれのほんですか。",
          "romaji": "kore wa dare no hon desu ka.",
          "es": "¿De quién es este libro?"
        },
        {
          "kanji": "わたしのです。",
          "kana": "わたしのです。",
          "romaji": "watashi no desu.",
          "es": "Es mío."
        }
      ],
      "tags": [
        "2026-07-10",
        "gramática",
        "preguntas"
      ]
    },
    {
      "id": "2026-07-10:grammar:basho-wa-desu",
      "type": "grammar",
      "pattern": "ここは〜です ／ 〜はここです",
      "es": "El orden cambia el sentido (ser vs estar): «ここはトイレです» dice QUÉ es este sitio = «aquí es el baño»; «トイレはここです» dice DÓNDE está algo = «el baño está aquí».",
      "examples": [
        {
          "kanji": "ここはトイレです。",
          "kana": "ここはトイレです。",
          "romaji": "koko wa toire desu.",
          "es": "Aquí es el baño. (qué es este sitio)"
        },
        {
          "kanji": "トイレはここです。",
          "kana": "トイレはここです。",
          "romaji": "toire wa koko desu.",
          "es": "El baño está aquí. (dónde está)"
        }
      ],
      "tags": [
        "2026-07-10",
        "gramática",
        "partículas"
      ]
    }
  ],
  "kanji": [],
  "notes": [
    {
      "id": "2026-07-10:note:1",
      "type": "note",
      "es": "En la clase presencial se terminó la PRIMERA RONDA del hiragana: las últimas letras fueron ら・り・る・れ・ろ, わ, を y ん. ¡Ya se puede leer todo el hiragana! (おめでとうございます).",
      "tags": [
        "2026-07-10",
        "nota",
        "hiragana"
      ]
    },
    {
      "id": "2026-07-10:note:2",
      "type": "note",
      "es": "を es una letra propia pero se pronuncia «o». Hoy en día solo aparece como PARTÍCULA (nunca dentro de una palabra); antiguamente se decía «wo».",
      "tags": [
        "2026-07-10",
        "nota",
        "hiragana",
        "partículas"
      ]
    },
    {
      "id": "2026-07-10:note:3",
      "type": "note",
      "es": "«Persona»: ひと es la palabra normal y かた es la forma educada (このかた = «esta persona», con respeto). El mismo kanji 人 se lee ひと o じん según el caso (recuerda país + じん = nacionalidad).",
      "tags": [
        "2026-07-10",
        "nota",
        "vocabulario",
        "cortesía"
      ]
    },
    {
      "id": "2026-07-10:note:4",
      "type": "note",
      "es": "Formalidad: toda frase que acaba en です ya es lenguaje formal (keigo). El japonés cambia bastante según con quién hablas; más adelante se verán los niveles honorífico y humilde.",
      "tags": [
        "2026-07-10",
        "nota",
        "cultura",
        "cortesía"
      ]
    }
  ]
}
